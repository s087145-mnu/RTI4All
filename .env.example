# RTI4All — example environment file
# Copy this file to `.env` (which is gitignored) and fill in real values.
#
#   cp .env.example .env
#
# All variables are optional — the stack will boot without an `.env` file,
# but the AI step will short-circuit to a stub response without a key.

# Anthropic Messages API key. Used by:
#   - Structurer agent  (claude-3-5-sonnet)
#   - Drafter agent     (claude-haiku-4-5)
# Leave empty for offline/local development; AI will return a stub.
ANTHROPIC_API_KEY=

# HS256 signing key for JWTs issued by /api/auth/login and /api/auth/signup.
# Generate one with:  openssl rand -base64 32
JWT_SECRET_KEY=replace-me-with-a-long-random-string

# Comma-separated list of emails that get is_admin=true at signup/login.
# Default seed user `officer@gov.mv` must be in this list to access /admin.
ADMIN_EMAILS=officer@gov.mv

# Optional model overrides (defaults shown).
# ANTHROPIC_MODEL=claude-haiku-4-5
# ANTHROPIC_STRUCTURE_MODEL=claude-3-5-sonnet-20241022

# Optional persistence tuning.
# ENABLE_DATA_PERSISTENCE=true
# MAX_BACKUPS=10
