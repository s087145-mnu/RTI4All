# ─── OS / editor ─────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Python (backend) ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# ─── Node (frontend) ─────────────────────────────────────────────────────
node_modules/
dist/
build/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Docker / local infra ────────────────────────────────────────────────
docker-compose.override.yml

# ─── Secrets & local config ──────────────────────────────────────────────
# Never commit .env files — they hold ANTHROPIC_API_KEY, JWT_SECRET_KEY, etc.
.env
.env.*
!.env.example

# ─── Project artifacts ───────────────────────────────────────────────────
# RAG cache (embedding matrix + ids), if/when persisted to disk.
backend/.rag_cache/
backend/*.faiss
backend/*.npy

# Hugging Face / transformers model cache (in case someone runs outside Docker).
.cache/huggingface/

# Hackathon scratchpads, ad-hoc test outputs.
/tmp/
*.bak
