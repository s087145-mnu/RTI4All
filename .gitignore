# ─── OS / editor ─────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Python (legacy backend) ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# ─── Go (backend-go) ─────────────────────────────────────────────────────
# The compiled binary lands at the repo root or inside the build dir.
/backend-go/rti4all
/backend-go/backend-go
*.test
*.out
# graphify-style on-disk caches if/when persisted.
backend-go/.rag_cache/
backend-go/data/backups/

# ─── Node (frontend) ─────────────────────────────────────────────────────
node_modules/
dist/
build/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Docker / local infra ────────────────────────────────────────────────
docker-compose.override.yml

# ─── Secrets & local config ──────────────────────────────────────────────
# Never commit .env files — they hold ANTHROPIC_API_KEY, JWT_SECRET_KEY, etc.
.env
.env.*
!.env.example

# ─── Project artifacts (Python era) ──────────────────────────────────────
backend/.rag_cache/
backend/*.faiss
backend/*.npy

# Hugging Face / transformers model cache (Python era).
.cache/huggingface/

# Hackathon scratchpads, ad-hoc test outputs.
/tmp/
*.bak
